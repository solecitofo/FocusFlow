{
  "type": "module",
  "name": "FocusFlow",
  "version": "2.0.0",
  "description": "Agenda cognitivo-conductual para personas con TDAH",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development electron .",
    "package": "vite build && electron-builder",
    "package-win": "vite build && electron-builder --win",
    "package-mac": "vite build && electron-builder --mac",
    "package-linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "lucide-react": "^0.561.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.23",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.tdah.focusflow",
    "productName": "FocusFlow",
    "asar": false,
    "files": [
      "dist/**/*",
      "electron.js"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
